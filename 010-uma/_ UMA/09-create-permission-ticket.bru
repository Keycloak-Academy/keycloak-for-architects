meta {
  name: Create Permission Ticket
  type: http
  seq: 9
}

post {
  url: {{KC_URL}}/realms/{{KC_REALM}}/authz/protection/permission
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{KC_TOKEN}}
  Content-Type: application/json
}

body:json {
  [{
      "resource_id": "{{RESOURCE_ID}}",
      "resource_scopes": [
        "view"
      ]
  }]
}

script:post-response {
  var data = res.getBody();
  bru.setEnvVar("PERM_TICKET", data.ticket);
}
