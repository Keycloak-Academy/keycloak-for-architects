meta {
  name: Get Permission Tickets
  type: http
  seq: 12
}

get {
  url: {{KC_URL}}/realms/{{KC_REALM}}/authz/protection/permission/ticket
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{KC_PAT}}
}

script:post-response {
  var data = res.getBody();
  bru.setEnvVar("TICKET_ID", data[0].id);
}
